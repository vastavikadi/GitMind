# GitMind Configuration
# Copy this file to .env and fill in your values

# LLM Provider
# Which LLM provider to use: "gemini" or "openai"
LLM_PROVIDER=gemini

# Google Gemini API key (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# Model names (optional — defaults are used if not set)
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# GitHub Personal Access Token (optional — enables GitHub agent)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=your-github-token

#LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=gitmind

# Embedding Provider
# Which embedding model to use: "gemini" or "openai"
EMBEDDING_PROVIDER=gemini
